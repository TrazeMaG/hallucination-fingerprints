\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Relation Dropout}{4}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Relation Dropout in our 806K-parameter model. Relation attention $< 0.05$ in the final block correlates with hallucination in 5 of 6 cases.}}{4}{table.1}\protected@file@percent }
\newlabel{tab:relation_dropout}{{1}{4}{Relation Dropout in our 806K-parameter model. Relation attention $< 0.05$ in the final block correlates with hallucination in 5 of 6 cases}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Attention to the relation token ``capital'' across all blocks and heads. Left: hallucination case --- final block attention collapses (highlighted box). Right: correct case --- attention maintained throughout. The divergence in the final block is the Relation Dropout signature.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:relation_dropout}{{1}{4}{Attention to the relation token ``capital'' across all blocks and heads. Left: hallucination case --- final block attention collapses (highlighted box). Right: correct case --- attention maintained throughout. The divergence in the final block is the Relation Dropout signature}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Last-Layer Suppression}{4}{subsection.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-layer probability of the correct answer versus the winning incorrect token across GPT-2's 12 blocks. The green shaded region (blocks 10--11) marks factual emergence; the red region (block 12) marks suppression. The Berlin Wall case (bottom right) survives because its factual signal exceeds the suppressor token probability at block 12 --- illustrating the survival threshold.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:layer_suppression}{{2}{5}{Per-layer probability of the correct answer versus the winning incorrect token across GPT-2's 12 blocks. The green shaded region (blocks 10--11) marks factual emergence; the red region (block 12) marks suppression. The Berlin Wall case (bottom right) survives because its factual signal exceeds the suppressor token probability at block 12 --- illustrating the survival threshold}{figure.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Peak factual layer and suppression layer for 4 prompts. Block 12 suppresses in every case. Average peak: 10.5. Average suppression: 12.0.}}{5}{table.2}\protected@file@percent }
\newlabel{tab:layers}{{2}{5}{Peak factual layer and suppression layer for 4 prompts. Block 12 suppresses in every case. Average peak: 10.5. Average suppression: 12.0}{table.2}{}}
