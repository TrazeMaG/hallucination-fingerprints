\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces GPT-2 hallucination taxonomy across 5 categories (35 prompts). Zero Type 1 cases: GPT-2 never shows Relation Dropout, suggesting this phenomenon is specific to small, undertrained models.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:gpt2}{{3}{6}{GPT-2 hallucination taxonomy across 5 categories (35 prompts). Zero Type 1 cases: GPT-2 never shows Relation Dropout, suggesting this phenomenon is specific to small, undertrained models}{table.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Large-Scale Validation}{6}{subsection.5.4}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Hallucination type distribution across 20,000 prompts on GPT-2. Average peak factual layer: 11.1. Average suppression layer: 12.0.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:largescale}{{4}{6}{Hallucination type distribution across 20,000 prompts on GPT-2. Average peak factual layer: 11.1. Average suppression layer: 12.0}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Left: distribution of hallucination types across 20,000 prompts. Knowledge Gap (68.1\%) dominates, reflecting the limits of GPT-2's training corpus. Right: accuracy by knowledge category. History achieves 30\% accuracy while authors achieves 0\% --- and alternative phrasings of the same factual query drop capital accuracy from 8.1\% to 0\%, illustrating extreme prompt sensitivity.}}{7}{figure.3}\protected@file@percent }
\newlabel{fig:taxonomy}{{3}{7}{Left: distribution of hallucination types across 20,000 prompts. Knowledge Gap (68.1\%) dominates, reflecting the limits of GPT-2's training corpus. Right: accuracy by knowledge category. History achieves 30\% accuracy while authors achieves 0\% --- and alternative phrasings of the same factual query drop capital accuracy from 8.1\% to 0\%, illustrating extreme prompt sensitivity}{figure.3}{}}
